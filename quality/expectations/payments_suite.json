{
  "expectation_suite_name": "payments_suite",
  "meta": {
    "notes": "Payment event checks for positive amounts, accepted methods, and outlier protection."
  },
  "expectations": [
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "payment_id"}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {"column": "amount_usd", "min_value": 0.01, "max_value": 10000000}
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "payment_method",
        "value_set": ["ach", "wire", "credit_card", "check", "unknown"]
      }
    },
    {
      "expectation_type": "expect_column_values_to_match_regex",
      "kwargs": {"column": "currency", "regex": "^[A-Z]{3}$"}
    }
  ]
}
